DEBUG=True
SECRET_KEY=rider-svc-secret-change-in-prod
ALLOWED_HOSTS=*

DATABASE_URL=postgres://yana_user:yana_secret@postgres:5432/yana_os

REDIS_URL=redis://redis:6379/1

# JWT (must match auth service)
JWT_SECRET_KEY=change-me-jwt-secret-key

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=yana_minio
MINIO_SECRET_KEY=yana_minio_secret
MINIO_BUCKET=yana-documents
MINIO_USE_SSL=False

# Encryption key for PII fields (Fernet)
PII_ENCRYPTION_KEY=change-me-32-byte-base64-encoded-key=

# Auth service internal URL (for token validation)
AUTH_SERVICE_URL=http://auth-service:8001

SERVICE_PORT=8002

# Celery
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2
