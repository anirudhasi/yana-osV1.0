# Auth Service Environment Configuration
DEBUG=True
SECRET_KEY=change-me-in-production-use-50-char-random-string
ALLOWED_HOSTS=*

# Database
DATABASE_URL=postgres://yana_user:yana_secret@postgres:5432/yana_os

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=30

# OTP
OTP_EXPIRY_SECONDS=300
OTP_SIMULATE=True   # Set False in prod to use real SMS

# Service
SERVICE_PORT=8001
